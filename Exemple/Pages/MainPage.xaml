<?xml version="1.0" encoding="utf-8" ?>
<extensions:ExtendedContentPage
    x:Class="Exemple.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:extensions="clr-namespace:MauiToolkit.Extensions;assembly=MauiToolkit.net"
    xmlns:viewModels="clr-namespace:Exemple.ViewModels"
    xmlns:controls="clr-namespace:MauiToolkit.Controls;assembly=MauiToolkit.net"
    xmlns:icons="clr-namespace:MauiToolkit.Fluent;assembly=MauiToolkit.net"
    x:TypeArguments="viewModels:MainPageViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <controls:FluentIcon Icon="Rocket" FontSize="34" />
                <Label Text="MauiToolkit.net Demo" FontSize="28" FontAttributes="Bold" />
            </HorizontalStackLayout>

            <Label Text="This page showcases all features currently available in the library." FontSize="14" />

            <Border StrokeThickness="1" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Features" FontAttributes="Bold" FontSize="18" />

                    <HorizontalStackLayout Spacing="10">
                        <controls:FluentIcon Icon="CheckmarkCircle" />
                        <Label Text="ExtendedContentPage&lt;TViewModel&gt; automatically triggers the ViewModel lifecycle." />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <controls:FluentIcon Icon="CheckmarkCircle" />
                        <Label Text="Navigation via INavigationService using the ViewModel -&gt; Page naming convention." />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <controls:FluentIcon Icon="CheckmarkCircle" />
                        <Label Text="FluentIcon, FluentIconButton, and FluentIconSourceExtension controls." />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <controls:FluentIcon Icon="CheckmarkCircle" />
                        <Label Text="ExtendedViewModel&lt;T&gt; and ILoadableViewModel&lt;T&gt; demonstrated on the Profile page." />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Open controls demo" Command="{Binding NavigateToCustomControls}" />

            <Button Text="Open Profile demo (LoadAsync)" Command="{Binding NavigateToProfile}" />

            <Image HeightRequest="44" WidthRequest="44" HorizontalOptions="Center">
                <Image.Source>
                    <icons:FluentIconSourceExtension Icon="Settings" Size="36" />
                </Image.Source>
            </Image>
        </VerticalStackLayout>
    </ScrollView>

</extensions:ExtendedContentPage>
