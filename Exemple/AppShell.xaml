<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Exemple.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Exemple"
    xmlns:icons="clr-namespace:MauiToolkit.Fluent;assembly=MauiToolkit.net"
    xmlns:pages="clr-namespace:Exemple.Pages"
    Title="Example">
    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.NavBarIsVisible" Value="False"/>
        </Style>
    </Shell.Resources>
    <TabBar>
        <ShellContent
            Icon="{icons:FluentIconSourceExtension Icon=Home, Size=20}"
            ContentTemplate="{DataTemplate pages:MainPage}"
            Route="MainPage" />
        <ShellContent
            Icon="{icons:FluentIconSourceExtension Icon=Apps, Size=20}"
            ContentTemplate="{DataTemplate pages:CustomControlPage}"
            Route="CustomControlPage" />
        <ShellContent
            Icon="{icons:FluentIconSourceExtension Icon=Person, Size=20}"
            ContentTemplate="{DataTemplate pages:ProfilePage}"
            Route="ProfilePage" />
    </TabBar>

</Shell>
